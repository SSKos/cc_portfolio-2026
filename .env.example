# Database (Prisma). For local Docker: postgresql://portfolio:portfolio@localhost:5432/portfolio
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# NextAuth. Generate: openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Analytics
NEXT_PUBLIC_PLAUSIBLE_DOMAIN="localhost"
# Self-hosted example: https://plausible.example.com/js/script.js
# Plausible cloud example: https://plausible.io/js/script.js
NEXT_PUBLIC_PLAUSIBLE_SRC=""
NEXT_PUBLIC_YANDEX_METRIKA_ID="108386731"
# Seed admin (only for npm run seed:admin)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="changeme"

# Figma API (only for npm run sync:figma-vars)
# Token: Figma → Account settings → Personal access tokens
FIGMA_ACCESS_TOKEN=""
# File key: из URL figma.com/design/{FILE_KEY}/...
FIGMA_FILE_KEY="tQSh2iLj0pzwGepcBtlMSf"

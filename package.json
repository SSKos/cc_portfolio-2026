{
  "name": "cc-portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "prisma generate && next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed:admin": "ts-node -r dotenv/config scripts/seed-admin.ts",
    "tokens": "npx ts-node scripts/tokens-to-css.ts",
    "sync:figma-vars": "npx ts-node scripts/sync-figma-vars.ts",
    "sandbox:new": "node --env-file=.env.local scripts/sandbox.mjs new",
    "sandbox:inject": "node --env-file=.env.local scripts/sandbox.mjs inject"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@types/bcryptjs": "^2.4.6",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.4",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5.9.3"
  }
}
